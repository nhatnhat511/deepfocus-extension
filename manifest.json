{
  "manifest_version": 3,
  "name": "DeepFocus Time - Smart Work Timer",
  "homepage_url": "https://deepfocustime.com",
  "version": "1.0",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "idle",
    "identity",
    "scripting",
    "offscreen",
    "notifications"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "commands": {
    "start-timer": {
      "suggested_key": {
        "default": "Alt+S"
      },
      "description": "Start timer"
    },
    "pause-resume": {
      "suggested_key": {
        "default": "Alt+P"
      },
      "description": "Pause or resume timer"
    },
    "reset-timer": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Reset timer"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "sounds/tick.MP3",
        "sounds/ding.MP3",
        "offscreen.html",
        "offscreen.js"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}




